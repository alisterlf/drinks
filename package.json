{
  "name": "drinks",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "start": "npm run dev",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "npm run typecheck && npm run lint:js && npm run lint:css && npm run lint:html && npm run validate:data",
    "lint:js": "eslint .",
    "typecheck": "tsc --noEmit",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:html": "htmlhint \"*.html\"",
    "validate:data": "node scripts/validate-data.js",
    "format": "prettier --write \"**/*.{html,css,js,ts,json}\"",
    "format:check": "prettier --check \"**/*.{html,css,js,ts,json}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "htmlhint": "^1.9.2",
    "prettier": "^3.8.4",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16"
  }
}
