{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Start Vite and Open Browser",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev -- --open",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug Vite in Edge",
      "type": "msedge",
      "request": "launch",
      "url": "http://127.0.0.1:5173/",
      "webRoot": "${workspaceFolder}",
      "userDataDir": "${workspaceFolder}/.vscode/.edge-debug-profile"
    }
  ]
}
